{
  "name": "remove-unused-imports",
  "displayName": "Remove Unused Imports",
  "version": "0.0.0-development",
  "description": "Removes unused ES6 imports in JavaScript and TypeScript files without changing the order",
  "categories": [
    "Formatters",
    "Programming Languages"
  ],
  "keywords": [
    "imports",
    "cleanup",
    "formatting",
    "javascript",
    "ES modules"
  ],
  "homepage": "https://github.com/kcmr/vsce-remove-unused-imports#readme",
  "bugs": {
    "url": "https://github.com/kcmr/vsce-remove-unused-imports/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kcmr/vsce-remove-unused-imports.git"
  },
  "license": "MIT",
  "author": "Kus Cámara",
  "publisher": "kuscamara",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remove-unused-imports.main",
        "title": "Remove Unused Imports"
      }
    ],
    "configuration": {
      "title": "Remove Unused Imports",
      "properties": {
        "removeUnusedImports.preserve": {
          "type": "array",
          "default": [],
          "description": "List of import identifiers to preserve. Example: ['React', 'ReactDOM']"
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:typescriptreact"
  ],
  "engines": {
    "vscode": "^1.0.0"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#212121",
    "theme": "dark"
  },
  "scripts": {
    "vscode:prepublish": "npm run build -- --minify",
    "clean": "rimraf dist",
    "build": "npm run clean && esbuild \"./src/extension.ts\" --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run clean && npm run build -- --sourcemap --watch",
    "compile": "npm run clean && tsc -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "jest",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"**/*.{js,ts,md,json}\"",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-syntax-import-attributes": "^7.28.6",
    "@babel/plugin-syntax-jsx": "^7.28.6",
    "@babel/plugin-syntax-typescript": "^7.28.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/babel__core": "^7.20.5",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.24.0",
    "eslint-plugin-jest": "^27.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-promise": "^6.0.0",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "recast": "^0.23.11",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "semantic-release-vsce": "^6.1.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "src/*.ts": "eslint --cache --fix",
    "*": "prettier --ignore-unknown --write"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm t"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "package-lock.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]"
        }
      ],
      [
        "semantic-release-vsce",
        {
          "publish": true,
          "packageVsix": true
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "*.vsix",
              "label": "vsce-remove-unused-imports-${nextRelease.version}.vsix"
            }
          ]
        }
      ]
    ],
    "branches": [
      "master"
    ]
  }
}
